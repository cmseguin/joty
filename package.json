{
  "name": "joty-ui",
  "version": "1.0.1",
  "type": "module",
  "bin": {
    "joty": "dist/bin/joty"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cmseguin/joty.git"
  },
  "author": "cmseguin",
  "contributors": [
    "cmseguin (https://github.com/cmseguin)"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run build:vite && npm run build:bin",
    "build:bin": "bun build ./src/joty.ts --compile --outfile dist/bin/joty",
    "build:vite": "vite build",
    "prepare": "npm run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@dnd-kit/react": "^0.3.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/bun": "^1.3.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^16.5.0",
    "js-yaml": "^4.1.1",
    "lexorank": "^1.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup-plugin-react-scoped-css": "^1.2.2",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  }
}
